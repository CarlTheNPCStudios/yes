local function IsGlove(tool)
	if tool:FindFirstChild("Glove") or tool:FindFirstChild("Hand") or tool:FindFirstChild("glove") or tool:FindFirstChild("hand") then
		return true
	end
	return false
end

local function FindGlove()
	local char = GetChar()
	for i,v in pairs(char:GetChildren()) do
		if v:IsA("Tool") then
			if IsGlove(v) then
				return v
			end
		end
	end
	for i,v in pairs(plr.Backpack:GetChildren()) do
		if v:IsA("Tool") then
			if IsGlove(v) then
				return v
			end
		end
	end
return nil
end

