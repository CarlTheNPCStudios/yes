local ImageUrl = "https://raw.githubusercontent.com/CarlTheNPCStudios/yes/main/image_2026-06-23_200413004.png" --your https:// url
local Mp3Url = "https://github.com/CarlTheNPCStudios/yes/raw/refs/heads/main/SPOILER__dudezzz0_musicaldown.com_1776513649.mp3" --your https:// url
local ImageKey = "tripleTImage.png"
local Mp3Key = "tripleTSound.mp3"

writefile(ImageKey, game:HttpGet(ImageUrl))
writefile(Mp3Key, game:HttpGet(Mp3Url))
local Imageasset = getcustomasset(ImageKey)
local Mp3asset = getcustomasset(Mp3Key)

local gui = Instance.new("ScreenGui",game.CoreGui)
gui.IgnoreGuiInset = true
gui.DisplayOrder = 999
gui.ZIndexBehavior = Enum.ZIndexBehavior.Global

local image = Instance.new("ImageLabel",gui)
image.Size = UDim2.new(1,0,1,0)
image.BackgroundTransparency = 1
image.Image = Imageasset
local sound = Instance.new("Sound",gui)
sound.Looped = true
sound.SoundId = Mp3asset
sound.Volume = 10
sound:Play()
